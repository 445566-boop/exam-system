# ===========================================
# 智能试卷管理系统 - 本地部署环境变量配置
# ===========================================

# 1. 数据库配置 (必填)
# 方案A: 使用 Supabase (云端)
COZE_SUPABASE_URL=https://your-project.supabase.co
COZE_SUPABASE_ANON_KEY=your-anon-key

# 方案B: 使用本地 PostgreSQL
# DATABASE_URL=postgresql://user:password@localhost:5432/exam_system

# 2. LLM 服务配置 (必填，用于题库解析和试卷批改)
# 方案A: 使用 OpenAI API
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# 方案B: 使用兼容 OpenAI 格式的 API (如 DeepSeek、火山引擎等)
# OPENAI_API_KEY=your-api-key
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat

# 方案C: 使用 Coze LLM (如需在本地保留 Coze 集成)
# COZE_API_KEY=your-coze-api-key
# COZE_BASE_URL=https://api.coze.cn/v1
# COZE_MODEL=doubao-seed-1.5-25hp-sft-32k

# 3. 文件存储配置 (可选)
# 方案A: 使用本地文件存储
USE_LOCAL_STORAGE=true
LOCAL_STORAGE_PATH=./uploads

# 方案B: 使用 S3 兼容存储 (如 MinIO)
# S3_ENDPOINT=http://localhost:9000
# S3_REGION=us-east-1
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key
# S3_BUCKET=exam-system

# 4. 应用配置 (可选)
NEXT_PUBLIC_APP_URL=http://localhost:3000
